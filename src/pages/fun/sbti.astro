  const DIM_EXPLANATIONS = {
    S1: { L: "对自己下手比别人还狠，夸你两句你都想先验明真伪。", M: "自信值随天气波动，顺风能飞，逆风先缩。", H: "心里对自己大致有数，不太会被路人一句话打散。" },
    S2: { L: "内心频道雪花较多，常在”我是谁”里循环缓存。", M: "平时还能认出自己，偶尔也会被情绪临时换号。", H: "对自己的脾气、欲望和底线都算门儿清。" },
    S3: { L: "更在意舒服和安全，没必要天天给人生开冲刺模式。", M: "想上进，也想躺会儿，价值排序经常内部开会。", H: "很容易被目标、成长或某种重要信念推着往前。" },
    E1: { L: "感情里警报器灵敏，已读不回都能脑补到大结局。", M: "一半信任，一半试探，感情里常在心里拉锯。", H: "更愿意相信关系本身，不会被一点风吹草动吓散。" },
    E2: { L: "感情投入偏克制，心门不是没开，是门禁太严。", M: "会投入，但会给自己留后手，不至于全盘梭哈。", H: "一旦认定就容易认真，情绪和精力都给得很足。" },
    E3: { L: "容易黏人也容易被黏，关系里的温度感很重要。", M: "亲密和独立都要一点，属于可调节型依赖。", H: "空间感很重要，再爱也得留一块属于自己的地。" },
    A1: { L: "看世界自带防御滤镜，先怀疑，再靠近。", M: "既不天真也不彻底阴谋论，观望是你的本能。", H: "更愿意相信人性和善意，遇事不急着把世界判死刑。" },
    A2: { L: "规则能绕就绕，舒服和自由往往排在前面。", M: "该守的时候守，该变通的时候也不死磕。", H: "秩序感较强，能按流程来就不爱即兴炸场。" },
    A3: { L: "意义感偏低，容易觉得很多事都像在走过场。", M: "偶尔有目标，偶尔也想摆烂，人生观处于半开机。", H: "做事更有方向，知道自己大概要往哪边走。" },
    Ac1: { L: "做事先考虑别翻车，避险系统比野心更先启动。", M: "有时想赢，有时只想别麻烦，动机比较混合。", H: "更容易被成果、成长和推进感点燃。" },
    Ac2: { L: "做决定前容易多转几圈，脑内会议常常超时。", M: "会想，但不至于想死机，属于正常犹豫。", H: "拍板速度快，决定一下就不爱回头磨叽。" },
    Ac3: { L: "执行力和死线有深厚感情，越晚越像要觉醒。", M: "能做，但状态看时机，偶尔稳偶尔摆。", H: "推进欲比较强，事情不落地心里都像卡了根刺。" },
    So1: { L: "社交启动慢热，主动出击这事通常得攒半天气。", M: "有人来就接，没人来也不硬凑，社交弹性一般。", H: "更愿意主动打开场子，在人群里不太怕露头。" },
    So2: { L: "关系里更想亲近和融合，熟了就容易把人划进内圈。", M: "既想亲近又想留缝，边界感看对象调节。", H: "边界感偏强，靠太近会先本能性后退半步。" },
    So3: { L: "表达更直接，心里有啥基本不爱绕。", M: "会看气氛说话，真实和体面通常各留一点。", H: "对不同场景的自我切换更熟练，真实感会分层发放。" }
  };

  const dimensionOrder = ['S1','S2','S3','E1','E2','E3','A1','A2','A3','Ac1','Ac2','Ac3','So1','So2','So3'];
  const DRUNK_TRIGGER_QUESTION_ID = 'drink_gate_q2';

  // ===== State =====
  const app = { shuffledQuestions: [], answers: {} };

  const screens = {
    intro: document.getElementById('sbti-intro'),
    test: document.getElementById('sbti-test'),
    result: document.getElementById('sbti-result')
  };

  const questionList = document.getElementById('sbti-question-list');
  const progressBar = document.getElementById('sbti-progress-bar');
  const progressText = document.getElementById('sbti-progress-text');
  const submitBtn = document.getElementById('sbti-submit-btn');
  const testHint = document.getElementById('sbti-test-hint');

  function showScreen(name) {
    Object.entries(screens).forEach(([key, el]) => {
      el.classList.toggle('sbti-active', key === name);
    });
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function shuffle(array) {
    const arr = [...array];
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
  }

  function getVisibleQuestions() {
    const visible = [...app.shuffledQuestions];
    const gateIndex = visible.findIndex(q => q.id === 'drink_gate_q1');
    if (gateIndex !== -1 && app.answers['drink_gate_q1'] === 3) {
      visible.splice(gateIndex + 1, 0, specialQuestions[1]);
    }
    return visible;
  }

  function getQuestionMetaLabel(q) {
    if (q.special) return '补充题';
    return dimensionMeta[q.dim].name;
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  function renderQuestions() {
    const visibleQuestions = getVisibleQuestions();
    questionList.innerHTML = '';
    visibleQuestions.forEach((q, index) => {
      const card = document.createElement('article');
      card.className = 'sbti-question';
      card.id = `sbti-q-${index + 1}`;
      const optionsHtml = q.options.map((opt, i) => {
        const code = ['A', 'B', 'C', 'D'][i] || String(i + 1);
        const checked = app.answers[q.id] === opt.value ? 'checked' : '';
        let mid;
        if (q.id === 'drink_gate_q1') {
          mid = opt.value === 3
            ? `${escapeHtml(opt.label)}<span class="sbti-delta sbti-delta-special">*</span>`
            : escapeHtml(opt.label);
        } else if (q.id === 'drink_gate_q2') {
          mid = opt.value === 2
            ? `${escapeHtml(opt.label)}<span class="sbti-delta sbti-delta-special">*</span>`
            : escapeHtml(opt.label);
        } else {
          const delta = opt.value - 2;
          const cls = delta > 0 ? 'sbti-delta-pos' : delta < 0 ? 'sbti-delta-neg' : 'sbti-delta-neu';
          const sign = delta > 0 ? `+${delta}` : `${delta}`;
          mid = `${escapeHtml(opt.label)}<span class="sbti-delta ${cls}">${sign}</span>`;
        }
        return `
          <label class="sbti-option">
            <input type="radio" name="${q.id}" value="${opt.value}" ${checked} />
            <div class="sbti-option-code">${code}</div>
            <div class="sbti-option-text">${mid}</div>
          </label>
        `;
      }).join('');

      card.innerHTML = `
        <div class="sbti-question-meta">
          <div class="sbti-badge">第 ${index + 1} 题</div>
          <div class="sbti-question-dim">${escapeHtml(getQuestionMetaLabel(q))}</div>
        </div>
        <div class="sbti-question-title">${escapeHtml(q.text)}</div>
        <div class="sbti-options">${optionsHtml}</div>
      `;
      questionList.appendChild(card);
    });

    questionList.querySelectorAll('input[type="radio"]').forEach(input => {
      input.addEventListener('change', (e) => {
        const target = e.target;
        const name = target.name;
        const value = target.value;
        app.answers[name] = Number(value);

        if (name === 'drink_gate_q1') {
          if (Number(value) !== 3) delete app.answers['drink_gate_q2'];
          renderQuestions();
          return;
        }
        updateProgress();
        updateLiveStatus();
        renderStatusGrid();
      });
    });

    updateProgress();
    updateLiveStatus();
    renderStatusGrid();
  }

  function updateProgress() {
    const visibleQuestions = getVisibleQuestions();
    const total = visibleQuestions.length;
    const done = visibleQuestions.filter(q => app.answers[q.id] !== undefined).length;
    const percent = total ? (done / total) * 100 : 0;
    progressBar.style.width = `${percent}%`;
    progressText.textContent = `${done} / ${total}`;
    const fabCount = document.getElementById('sbti-fab-count');
    if (fabCount) fabCount.textContent = `${done} / ${total}`;
    const complete = done === total && total > 0;
    submitBtn.disabled = !complete;
    testHint.textContent = complete
      ? '都做完了，可以提交看看结果了。'
      : '全部选完才会放行。';
  }

  function renderStatusGrid() {
    const grid = document.getElementById('sbti-status-grid');
    if (!grid) return;
    const visibleQuestions = getVisibleQuestions();
    grid.innerHTML = visibleQuestions.map((q, index) => {
      const num = index + 1;
      const done = app.answers[q.id] !== undefined;
      const cls = done ? 'sbti-chip-done' : 'sbti-chip-pending';
      return `<button type="button" class="sbti-status-chip ${cls}" data-target="sbti-q-${num}">${num}</button>`;
    }).join('');
    grid.querySelectorAll('button[data-target]').forEach(btn => {
      btn.addEventListener('click', () => {
        const el = document.getElementById(btn.dataset.target);
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
        closeStatusGrid();
      });
    });
  }

  function openStatusGrid() {
    const wrap = document.getElementById('sbti-status-grid-wrap');
    wrap.removeAttribute('hidden');
    renderStatusGrid();
  }

  function closeStatusGrid() {
    const wrap = document.getElementById('sbti-status-grid-wrap');
    wrap.setAttribute('hidden', '');
  }

  function sumToLevel(score) {
    if (score <= 3) return 'L';
    if (score === 4) return 'M';
    return 'H';
  }
  function levelNum(level) { return { L: 1, M: 2, H: 3 }[level]; }
  function parsePattern(pattern) { return pattern.replace(/-/g, '').split(''); }
  function getDrunkTriggered() { return app.answers[DRUNK_TRIGGER_QUESTION_ID] === 2; }

  function computeResult() {
    const rawScores = {};
    const levels = {};
    Object.keys(dimensionMeta).forEach(dim => { rawScores[dim] = 0; });
    questions.forEach(q => { rawScores[q.dim] += Number(app.answers[q.id] || 0); });
    Object.entries(rawScores).forEach(([dim, score]) => { levels[dim] = sumToLevel(score); });

    const userVector = dimensionOrder.map(dim => levelNum(levels[dim]));
    const ranked = NORMAL_TYPES.map(type => {
      const vector = parsePattern(type.pattern).map(levelNum);
      let distance = 0, exact = 0;
      for (let i = 0; i < vector.length; i++) {
        const diff = Math.abs(userVector[i] - vector[i]);
        distance += diff;
        if (diff === 0) exact += 1;
      }
      const similarity = Math.max(0, Math.round((1 - distance / 30) * 100));
      return { ...type, ...TYPE_LIBRARY[type.code], distance, exact, similarity };
    }).sort((a, b) => {
      if (a.distance !== b.distance) return a.distance - b.distance;
      if (b.exact !== a.exact) return b.exact - a.exact;
      return b.similarity - a.similarity;
    });

    const bestNormal = ranked[0];
    const drunkTriggered = getDrunkTriggered();

    let finalType, modeKicker = '你的主人格';
    let badge = `匹配度 ${bestNormal.similarity}% · 精准命中 ${bestNormal.exact}/15 维`;
    let sub = '维度命中度较高，可视为你的第一人格画像。';
    let special = false;

    if (drunkTriggered) {
      finalType = TYPE_LIBRARY.DRUNK;
      modeKicker = '隐藏人格已激活';
      badge = '匹配度 100% · 酒精异常因子已接管';
      sub = '乙醇亲和性过强，系统已直接跳过常规人格审判。';
      special = true;
    } else if (bestNormal.similarity < 60) {
      finalType = TYPE_LIBRARY.HHHH;
      modeKicker = '系统强制兜底';
      badge = `标准人格库最高匹配仅 ${bestNormal.similarity}%`;
      sub = '标准人格库对你的脑回路集体罢工了，于是系统把你强制分配给了 HHHH。';
      special = true;
    } else {
      finalType = bestNormal;
    }

    return { rawScores, levels, ranked, bestNormal, finalType, modeKicker, badge, sub, special };
  }

  function renderDimList(result) {
    const dimList = document.getElementById('sbti-dim-list');
    dimList.innerHTML = dimensionOrder.map(dim => {
      const level = result.levels[dim];
      const explanation = DIM_EXPLANATIONS[dim][level];
      return `
        <div class="sbti-dim-item">
          <div class="sbti-dim-top">
            <div class="sbti-dim-name">${dimensionMeta[dim].name}</div>
            <div class="sbti-dim-score sbti-level-${level}">${level} · ${result.rawScores[dim]}分</div>
          </div>
          <p>${escapeHtml(explanation)}</p>
        </div>
      `;
    }).join('');
  }

  function renderResult() {
    const result = computeResult();
    const type = result.finalType;

    document.getElementById('sbti-result-kicker').textContent = result.modeKicker;
    document.getElementById('sbti-result-name').textContent = `${type.code}（${type.cn}）`;
    document.getElementById('sbti-match-badge').textContent = result.badge;
    document.getElementById('sbti-result-sub').textContent = result.sub;
    document.getElementById('sbti-result-desc').textContent = type.desc;
    document.getElementById('sbti-poster-caption').textContent = type.intro;
    document.getElementById('sbti-fun-note').textContent = result.special
      ? '本测试仅供娱乐。隐藏人格和傻乐兜底都是作者故意埋的损招，请勿当成医学、心理学、相学或命理依据。'
      : '本测试仅供娱乐，别拿它当诊断、面试、相亲、分手或人生判决书。你可以笑，但别太当真。';

    const posterBox = document.getElementById('sbti-poster-box');
    const posterImg = document.getElementById('sbti-poster-img');
    const imageSrc = TYPE_IMAGES[type.code];
    if (imageSrc) {
      posterImg.src = imageSrc;
      posterImg.alt = `${type.code}（${type.cn}）`;
      posterBox.classList.remove('sbti-no-image');
    } else {
      posterImg.removeAttribute('src');
      posterImg.alt = '';
      posterBox.classList.add('sbti-no-image');
    }

    renderDimList(result);
    showScreen('result');
  }

  function startTest() {
    app.answers = {};
    const shuffledRegular = shuffle(questions);
    const insertIndex = Math.floor(Math.random() * shuffledRegular.length) + 1;
    app.shuffledQuestions = [
      ...shuffledRegular.slice(0, insertIndex),
      specialQuestions[0],
      ...shuffledRegular.slice(insertIndex)
    ];
    renderQuestions();
    showScreen('test');
  }

  // ===== Live status bar =====
  function computeLiveScores() {
    const rawScores = {};
    Object.keys(dimensionMeta).forEach(dim => {
      const count = questions.filter(q => q.dim === dim).length;
      rawScores[dim] = count * 2;
    });
    questions.forEach(q => {
      if (app.answers[q.id] !== undefined) {
        rawScores[q.dim] += Number(app.answers[q.id]) - 2;
      }
    });

    const levels = {};
    Object.entries(rawScores).forEach(([dim, score]) => { levels[dim] = sumToLevel(score); });
    const userVector = dimensionOrder.map(dim => levelNum(levels[dim]));

    const ranked = NORMAL_TYPES.map(type => {
      const vector = parsePattern(type.pattern).map(levelNum);
      let distance = 0, exact = 0;
      for (let i = 0; i < vector.length; i++) {
        const diff = Math.abs(userVector[i] - vector[i]);
        distance += diff;
        if (diff === 0) exact++;
      }
      const similarity = Math.max(0, Math.round((1 - distance / 30) * 100));
      return { ...type, distance, exact, similarity };
    }).sort((a, b) => {
      if (a.distance !== b.distance) return a.distance - b.distance;
      if (b.exact !== a.exact) return b.exact - a.exact;
      return b.similarity - a.similarity;
    });

    const drunkQ1 = app.answers['drink_gate_q1'] === 3;
    const drunkQ2 = app.answers['drink_gate_q2'] === 2;
    const drunkTriggered = drunkQ1 && drunkQ2;
    const hhhhTriggered = !drunkTriggered && ranked[0].similarity < 60;

    let bestType;
    if (drunkTriggered) bestType = { code: 'DRUNK', cn: '酒鬼', similarity: 100, special: true };
    else if (hhhhTriggered) bestType = { code: 'HHHH', cn: '傻乐者', similarity: 100, special: true };
    else bestType = ranked[0];

    return { levels, rawScores, ranked, bestType, drunkQ1, drunkQ2 };
  }

  function renderDropdownContent() {
    const { ranked, drunkQ1, drunkQ2 } = computeLiveScores();

    const markersEl = document.getElementById('sbti-drunk-markers');
    markersEl.innerHTML = `
      <span class="sbti-drunk-marker ${drunkQ1 ? 'sbti-active-marker' : 'sbti-inactive-marker'}">
        ${drunkQ1 ? '✓' : '✗'} 爱好：饮酒
      </span>
      <span class="sbti-drunk-marker ${drunkQ2 ? 'sbti-active-marker' : 'sbti-inactive-marker'} ${!drunkQ1 ? 'sbti-dimmed' : ''}">
        ${drunkQ2 ? '✓' : '✗'} 酒精令我信服
      </span>
    `;

    const minDistance = ranked[0].distance;
    const maxExact = ranked
      .filter(t => t.distance === minDistance)
      .reduce((m, t) => Math.max(m, t.exact), 0);

    const grid = document.getElementById('sbti-dropdown-grid');
    grid.innerHTML = ranked.map(t => {
      const isTop = t.distance === minDistance && t.exact === maxExact;
      return `
        <div class="sbti-type-row${isTop ? ' sbti-top-match' : ''}">
          <div>
            <div class="sbti-type-code">${t.code}</div>
            <div class="sbti-type-cn">${TYPE_LIBRARY[t.code]?.cn || ''}</div>
          </div>
          <div class="sbti-type-stats">
            <strong>${t.similarity}%</strong>
            <span>${t.exact}/15 维</span>
          </div>
        </div>
      `;
    }).join('');
  }

  function updateLiveStatus() {
    const { levels, rawScores, bestType } = computeLiveScores();

    document.getElementById('sbti-best-match').textContent =
      `主人格：${bestType.code} ${bestType.similarity}%`;

    document.getElementById('sbti-status-dims').innerHTML = dimensionOrder.map(dim => {
      const lvl = levels[dim];
      return `<span class="sbti-dim-chip sbti-level-${lvl}" title="${dimensionMeta[dim].name}">${dim}:${lvl}</span>`;
    }).join('');

    const dropdown = document.getElementById('sbti-dropdown');
    if (dropdown.style.display !== 'none' && dropdown.style.display !== '') {
      renderDropdownContent();
    }
  }

  document.getElementById('sbti-toggle-btn').addEventListener('click', () => {
    const dropdown = document.getElementById('sbti-dropdown');
    const btn = document.getElementById('sbti-toggle-btn');
    const open = dropdown.style.display === 'block';
    dropdown.style.display = open ? 'none' : 'block';
    btn.textContent = open ? '展开 ▼' : '收起 ▲';
    if (!open) renderDropdownContent();
  });

  document.getElementById('sbti-status-grid-btn').addEventListener('click', (e) => {
    e.stopPropagation();
    const wrap = document.getElementById('sbti-status-grid-wrap');
    if (wrap.hasAttribute('hidden')) openStatusGrid();
    else closeStatusGrid();
  });

  document.getElementById('sbti-status-grid-close').addEventListener('click', closeStatusGrid);

  // Click outside the popup closes it
  document.addEventListener('click', (e) => {
    const wrap = document.getElementById('sbti-status-grid-wrap');
    if (wrap.hasAttribute('hidden')) return;
    const fabWrap = e.target.closest('.sbti-fab-wrap');
    if (!fabWrap) closeStatusGrid();
  });

  document.getElementById('sbti-start-btn').addEventListener('click', startTest);
  document.getElementById('sbti-back-btn').addEventListener('click', () => showScreen('intro'));
  document.getElementById('sbti-submit-btn').addEventListener('click', renderResult);
  document.getElementById('sbti-restart-btn').addEventListener('click', startTest);
  document.getElementById('sbti-totop-btn').addEventListener('click', () => showScreen('intro'));
</script>

